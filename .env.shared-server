# ===============================
# RATE LIMITING (OPTIONAL)
# ===============================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ===============================
# MAGENTO INTEGRATION
# ===============================
MAGENTO_BASE_URL=https://magento-test.softdemonew.info
