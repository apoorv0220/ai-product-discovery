# ===============================
# LOGGING CONFIGURATION
# ===============================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===============================
# ENVIRONMENT SETTINGS
# ===============================
ENVIRONMENT=production
DEBUG=false

# ===============================
# CORS CONFIGURATION
# ===============================
CORS_ORIGINS=["http://ai-product-discovery.softdemonew.info:3000", "https://magento-test.softdemonew.info"]
