# Example: MAGENTO_BASE_URL=https://yourstore.com

# ===============================
# MONITORING (OPTIONAL)
# ===============================
ENABLE_METRICS=true
METRICS_PORT=9090

# ===============================
# SHARED SERVER SPECIFIC
# ===============================
# User and group for file permissions
