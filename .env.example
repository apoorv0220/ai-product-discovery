# AI Product Discovery Suite - Environment Configuration
# Copy this file to .env and customize the values

# Application
APP_NAME=AI Product Discovery Suite
VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://discovery:discovery123@localhost:5432/discovery_suite
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=discovery
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# Weaviate
WEAVIATE_URL=http://localhost:8065
WEAVIATE_API_KEY=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Security
SECRET_KEY=your-secret-key-change-in-production-make-it-very-long-and-random
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8065","http://localhost:8091"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
SENTRY_DSN=

# ML Models
MODEL_CACHE_DIR=/tmp/models
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# OpenAI (Optional for enhanced AI features)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# Service Ports
SEARCH_SERVICE_PORT=8001
RECOMMENDATION_SERVICE_PORT=8002
LISTING_OPTIMIZER_PORT=8003
ANALYTICS_SERVICE_PORT=8004
SHOPPING_ASSISTANT_PORT=8005

# External Services
MAGENTO_BASE_URL=http://localhost/magento2
MAGENTO_API_TOKEN=your-magento-api-token
MAGENTO_API_USER=discovery-api-user