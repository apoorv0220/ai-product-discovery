<?xml version="1.0"?>
<!--
/**
 * DiscoverySuite Frontend Routes
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
        xsi:noNamespaceSchemaLocation="urn:magento:framework:App/etc/routes.xsd">
    <router id="standard">
        <route id="discoverysuite" frontName="discoverysuite">
            <module name="Vendor_DiscoverySuite" />
        </route>
        <route id="discovery" frontName="discovery">
            <module name="Vendor_DiscoverySuite" />
        </route>
        <route id="discovery_interactions" frontName="discovery_interactions">
            <module name="Vendor_DiscoverySuite" />
        </route>
        <route id="discovery_assistant" frontName="discovery_assistant">
            <module name="Vendor_DiscoverySuite" />
        </route>
    </router>
</config>
