<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <discovery_suite_config>
            <general>
                <enabled>1</enabled>
                <api_base_url>http://ai-product-discovery.softdemonew.info</api_base_url>
                <api_key></api_key>
                <timeout>30</timeout>
                <debug_mode>0</debug_mode>
            </general>
            <search>
                <enabled>1</enabled>
                <autocomplete_enabled>1</autocomplete_enabled>
                <autocomplete_min_chars>2</autocomplete_min_chars>
                <autocomplete_max_results>10</autocomplete_max_results>
                <typo_tolerance>1</typo_tolerance>
                <synonyms_enabled>1</synonyms_enabled>
                <nlp_enabled>1</nlp_enabled>
                <intent_recognition>1</intent_recognition>
                <semantic_search>1</semantic_search>
                <fallback_to_magento>1</fallback_to_magento>
            </search>
            <recommendations>
                <enabled>1</enabled>
                <homepage_enabled>1</homepage_enabled>
                <product_page_enabled>1</product_page_enabled>
                <cart_page_enabled>1</cart_page_enabled>
                <category_page_enabled>1</category_page_enabled>
                <max_recommendations>12</max_recommendations>
                <ml_powered>1</ml_powered>
                <real_time_learning>1</real_time_learning>
                <collaborative_filtering>1</collaborative_filtering>
                <content_based>1</content_based>
                <recommendation_types>cross_sell,up_sell,similar,trending</recommendation_types>
            </recommendations>
            <smart_listings>
                <enabled>1</enabled>
                <auto_sort_enabled>1</auto_sort_enabled>
                <dynamic_filters_enabled>1</dynamic_filters_enabled>
                <merchandising_enabled>1</merchandising_enabled>
                <boost_popular_products>1</boost_popular_products>
                <boost_high_margin>0</boost_high_margin>
                <ai_powered_sorting>1</ai_powered_sorting>
            </smart_listings>
            <shopping_assistant>
                <enabled>1</enabled>
                <widget_position>bottom_right</widget_position>
                <chat_enabled>1</chat_enabled>
                <guided_flow_enabled>1</guided_flow_enabled>
                <auto_trigger_delay>30</auto_trigger_delay>
                <conversational_ai>1</conversational_ai>
                <nlp_processing>1</nlp_processing>
                <multi_turn_conversations>1</multi_turn_conversations>
            </shopping_assistant>
            <analytics>
                <enabled>1</enabled>
                <track_searches>1</track_searches>
                <track_clicks>1</track_clicks>
                <track_purchases>1</track_purchases>
                <track_page_views>1</track_page_views>
                <ab_testing_enabled>1</ab_testing_enabled>
                <real_time_tracking>1</real_time_tracking>
                <behavioral_insights>1</behavioral_insights>
                <ab_testing>1</ab_testing>
                <predictive_analytics>1</predictive_analytics>
                <data_retention_days>365</data_retention_days>
            </analytics>
        </discovery_suite_config>
    </default>
</config>