<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    
    <!-- API Interface Preferences -->
    <preference for="Vendor\DiscoverySuite\Api\SearchInterface" 
                type="Vendor\DiscoverySuite\Model\Search\SearchService"/>
    <preference for="Vendor\DiscoverySuite\Api\RecommendationInterface" 
                type="Vendor\DiscoverySuite\Model\Recommendations\RecommendationService"/>
    <preference for="Vendor\DiscoverySuite\Api\AnalyticsInterface" 
                type="Vendor\DiscoverySuite\Model\Analytics\AnalyticsService"/>
    <preference for="Vendor\DiscoverySuite\Api\AssistantInterface" 
                type="Vendor\DiscoverySuite\Model\Assistant\AssistantService"/>
    
    <!-- Virtual Types for HTTP Clients -->
    <virtualType name="DiscoverySuiteSearchClient" type="Vendor\DiscoverySuite\Model\Api\HttpClient">
        <arguments>
            <argument name="baseUri" xsi:type="string">search-service</argument>
            <argument name="defaultPort" xsi:type="string">7001</argument>
        </arguments>
    </virtualType>
    
    <virtualType name="DiscoverySuiteRecommendationClient" type="Vendor\DiscoverySuite\Model\Api\HttpClient">
        <arguments>
            <argument name="baseUri" xsi:type="string">recommendation-service</argument>
            <argument name="defaultPort" xsi:type="string">7002</argument>
        </arguments>
    </virtualType>
    
    <virtualType name="DiscoverySuiteAnalyticsClient" type="Vendor\DiscoverySuite\Model\Api\HttpClient">
        <arguments>
            <argument name="baseUri" xsi:type="string">analytics-service</argument>
            <argument name="defaultPort" xsi:type="string">7003</argument>
        </arguments>
    </virtualType>
    
    <virtualType name="DiscoverySuiteAssistantClient" type="Vendor\DiscoverySuite\Model\Api\HttpClient">
        <arguments>
            <argument name="baseUri" xsi:type="string">shopping-assistant</argument>
            <argument name="defaultPort" xsi:type="string">7004</argument>
        </arguments>
    </virtualType>
    
    <!-- Console Commands -->
    <type name="Magento\Framework\Console\CommandList">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="discoveryTestConnection" xsi:type="object">Vendor\DiscoverySuite\Console\Command\TestConnection</item>
                <item name="discoverySyncCatalog" xsi:type="object">Vendor\DiscoverySuite\Console\Command\SyncCatalog</item>
                <item name="discoveryTestAdvancedAi" xsi:type="object">Vendor\DiscoverySuite\Console\Command\TestAdvancedAi</item>
            </argument>
        </arguments>
    </type>
    
    <!-- Service HTTP Client Injection -->
    <type name="Vendor\DiscoverySuite\Model\Search\SearchService">
        <arguments>
            <argument name="httpClient" xsi:type="object">DiscoverySuiteSearchClient</argument>
        </arguments>
    </type>
    
    <type name="Vendor\DiscoverySuite\Model\Recommendations\RecommendationService">
        <arguments>
            <argument name="httpClient" xsi:type="object">DiscoverySuiteRecommendationClient</argument>
        </arguments>
    </type>
    
    <type name="Vendor\DiscoverySuite\Model\Analytics\AnalyticsService">
        <arguments>
            <argument name="httpClient" xsi:type="object">DiscoverySuiteAnalyticsClient</argument>
        </arguments>
    </type>
    
    <type name="Vendor\DiscoverySuite\Model\Assistant\AssistantService">
        <arguments>
            <argument name="httpClient" xsi:type="object">DiscoverySuiteAssistantClient</argument>
        </arguments>
    </type>
    
</config>