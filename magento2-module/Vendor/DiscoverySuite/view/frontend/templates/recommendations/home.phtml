<script>
document.addEventListener('DOMContentLoaded', function() {
    const blockId = '<?= $block->escapeJs($blockId) ?>';
    const trackingUrl = '<?= $block->escapeJs($block->getTrackingUrl()) ?>';
    
    // Track recommendation impressions
    const cards = document.querySelectorAll('#' + blockId + ' .discovery-product-card');
    cards.forEach(function(card, index) {
        const productId = card.dataset.productId;
        
        // Track impression
        fetch(trackingUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({
                user_id: 'guest_<?= $block->escapeJs(session_id()) ?>',
                product_id: productId,
                interaction_type: 'impression',
                event_type: 'impression',
                context: 'home_recommendations',
                position: index + 1
            })
        }).catch(function(error) {
            console.log('Tracking error:', error);
        });
    });
    
    // Track clicks and interactions
    document.getElementById(blockId).addEventListener('click', function(e) {
        const target = e.target.closest('[data-action]');
        if (!target) return;
        
        const action = target.dataset.action;
        const productId = target.dataset.productId || target.closest('[data-product-id]').dataset.productId;
        const context = target.dataset.context;
        
        // Track the interaction
        fetch(trackingUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({
                user_id: 'guest_<?= $block->escapeJs(session_id()) ?>',
                product_id: productId,
                interaction_type: action,
                event_type: action === 'click' ? 'click' : action,
                context: context
            })
        }).catch(function(error) {
            console.log('Tracking error:', error);
        });
    });
});
</script>
