<script>
document.addEventListener('DOMContentLoaded', function() {
    const blockId = '<?= $block->escapeJs($blockId) ?>';
    const trackingUrl = '<?= $block->escapeJs($block->getTrackingUrl()) ?>';
    const currentProductId = '<?= $block->escapeJs($currentProduct->getId()) ?>';
    
    // Track recommendation impressions
    const slides = document.querySelectorAll('#' + blockId + ' .discovery-product-slide, #' + blockId + ' .discovery-product-card-small');
    slides.forEach(function(slide, index) {
        const productId = slide.dataset.productId;
        
        // Track impression
        fetch(trackingUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({
                user_id: 'guest_<?= $block->escapeJs(session_id()) ?>',
                product_id: productId,
                interaction_type: 'impression',
                event_type: 'impression',
                context: 'product_recommendations',
                reference_product_id: currentProductId,
                position: index + 1
            })
        }).catch(function(error) {
            console.log('Tracking error:', error);
        });
    });
    
    // Track clicks and interactions
    document.getElementById(blockId).addEventListener('click', function(e) {
        const target = e.target.closest('[data-action]');
        if (!target) return;
        
        const action = target.dataset.action;
        const productId = target.dataset.productId || target.closest('[data-product-id]').dataset.productId;
        const context = target.dataset.context;
        
        // Track the interaction
        fetch(trackingUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({
                user_id: 'guest_<?= $block->escapeJs(session_id()) ?>',
                product_id: productId,
                interaction_type: action,
                event_type: action === 'click' ? 'click' : action,
                context: context,
                reference_product_id: currentProductId
            })
        }).catch(function(error) {
            console.log('Tracking error:', error);
        });
    });
    
    // Simple slider functionality
    const sliders = document.querySelectorAll('#' + blockId + ' .discovery-products-slider');
    sliders.forEach(function(slider) {
        const track = slider.querySelector('.discovery-products-track');
        const prevBtn = slider.querySelector('.discovery-slider-prev');
        const nextBtn = slider.querySelector('.discovery-slider-next');
        
        if (prevBtn && nextBtn && track) {
            prevBtn.addEventListener('click', function() {
                track.scrollBy({ left: -240, behavior: 'smooth' });
            });
            
            nextBtn.addEventListener('click', function() {
                track.scrollBy({ left: 240, behavior: 'smooth' });
            });
        }
    });
});
</script>
