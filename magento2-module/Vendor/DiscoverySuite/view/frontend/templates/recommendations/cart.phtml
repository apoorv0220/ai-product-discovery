<script>
document.addEventListener('DOMContentLoaded', function() {
    const blockId = '<?= $block->escapeJs($blockId) ?>';
    const trackingUrl = '<?= $block->escapeJs($block->getTrackingUrl()) ?>';
    
    // Track recommendation impressions
    const cards = document.querySelectorAll('#' + blockId + ' .discovery-product-card, #' + blockId + ' .discovery-bundle-item');
    cards.forEach(function(card, index) {
        const productId = card.dataset.productId;
        
        // Track impression
        fetch(trackingUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({
                user_id: 'guest_<?= $block->escapeJs(session_id()) ?>',
                product_id: productId,
                interaction_type: 'impression',
                event_type: 'impression',
                context: 'cart_recommendations',
                position: index + 1,
                cart_total: <?= $block->escapeJs($cartTotal) ?>
            })
        }).catch(function(error) {
            console.log('Tracking error:', error);
        });
    });
    
    // Track clicks and interactions
    document.getElementById(blockId).addEventListener('click', function(e) {
        const target = e.target.closest('[data-action]');
        if (!target) return;
        
        const action = target.dataset.action;
        const productId = target.dataset.productId || target.closest('[data-product-id]').dataset.productId;
        const context = target.dataset.context;
        
        // Track the interaction
        fetch(trackingUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({
                user_id: 'guest_<?= $block->escapeJs(session_id()) ?>',
                product_id: productId,
                interaction_type: action,
                event_type: action === 'click' ? 'click' : action,
                context: context,
                cart_total: <?= $block->escapeJs($cartTotal) ?>
            })
        }).catch(function(error) {
            console.log('Tracking error:', error);
        });
        
        // Handle bundle add to cart
        if (action === 'add_bundle_to_cart') {
            const bundleItems = document.querySelectorAll('#' + blockId + ' .discovery-bundle-item');
            bundleItems.forEach(function(item) {
                const bundleProductId = item.dataset.productId;
                if (bundleProductId) {
                    // Track bundle item
                    fetch(trackingUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify({
                            user_id: 'guest_<?= $block->escapeJs(session_id()) ?>',
                            product_id: bundleProductId,
                            interaction_type: 'add_to_cart',
                            event_type: 'add_to_cart',
                            context: 'bundle_purchase'
                        })
                    });
                }
            });
        }
    });
});
</script>
