<?php
/**
 * DiscoverySuite Search Autocomplete Template
 *
 * @var \Vendor\DiscoverySuite\Block\Search\Autocomplete $block
 */
?>
<?php if ($block->isEnabled()): ?>
<div class="discovery-search-container" 
     data-mage-init='{"discoveryAutocomplete": <?= $block->getAutocompleteConfig() ?>}'>
    
    <div class="discovery-search-wrapper">
        <form class="form minisearch" id="discovery-search-form" action="<?= $block->getSearchUrl() ?>" method="get">
            <div class="field search">
                <label class="label" for="discovery-search">
                    <span><?= $block->escapeHtml(__('Search')) ?></span>
                </label>
                <div class="control">
                    <input id="discovery-search"
                           type="search"
                           name="q"
                           value="<?= $block->escapeHtml($block->getCurrentQuery()) ?>"
                           placeholder="<?= $block->escapeHtml($block->getSearchPlaceholder()) ?>"
                           class="input-text"
                           maxlength="128"
                           role="combobox"
                           aria-haspopup="false"
                           aria-autocomplete="both"
                           autocomplete="off"
                           aria-expanded="false"/>
                    
                    <div id="discovery-search-autocomplete" 
                         class="search autocomplete" 
                         style="display: none;">
                        <!-- Autocomplete results will be populated here -->
                    </div>
                </div>
            </div>
            <div class="actions">
                <button type="submit"
                        title="<?= $block->escapeHtml(__('Search')) ?>"
                        class="action search"
                        aria-label="Search">
                    <span><?= $block->escapeHtml(__('Search')) ?></span>
                </button>
            </div>
        </form>
    </div>
</div>

<script type="text/x-magento-template" id="discovery-autocomplete-template">
    <div class="discovery-autocomplete-results">
        <% if (data.suggestions && data.suggestions.length > 0) { %>
            <div class="autocomplete-section suggestions">
                <h4 class="section-title"><?= $block->escapeHtml(__('Suggestions')) ?></h4>
                <ul class="suggestion-list">
                    <% _.each(data.suggestions, function(suggestion) { %>
                        <li class="suggestion-item" data-suggestion="<%- suggestion.text %>">
                            <span class="suggestion-text"><%- suggestion.text %></span>
                            <% if (suggestion.count) { %>
                                <span class="suggestion-count">(<%- suggestion.count %>)</span>
                            <% } %>
                        </li>
                    <% }); %>
                </ul>
            </div>
        <% } %>
        
        <% if (data.products && data.products.length > 0) { %>
            <div class="autocomplete-section products">
                <h4 class="section-title"><?= $block->escapeHtml(__('Products')) ?></h4>
                <ul class="product-list">
                    <% _.each(data.products, function(product) { %>
                        <li class="product-item" data-product-id="<%- product.id %>">
                            <a href="<%- product.url %>" class="product-link">
                                <% if (product.image) { %>
                                    <img src="<%- product.image %>" 
                                         alt="<%- product.name %>" 
                                         class="product-image"/>
                                <% } %>
                                <div class="product-info">
                                    <span class="product-name"><%- product.name %></span>
                                    <% if (product.price) { %>
                                        <span class="product-price"><%- product.price %></span>
                                    <% } %>
                                </div>
                            </a>
                        </li>
                    <% }); %>
                </ul>
            </div>
        <% } %>
        
        <% if (data.categories && data.categories.length > 0) { %>
            <div class="autocomplete-section categories">
                <h4 class="section-title"><?= $block->escapeHtml(__('Categories')) ?></h4>
                <ul class="category-list">
                    <% _.each(data.categories, function(category) { %>
                        <li class="category-item">
                            <a href="<%- category.url %>" class="category-link">
                                <span class="category-name"><%- category.name %></span>
                                <% if (category.product_count) { %>
                                    <span class="category-count">(<%- category.product_count %>)</span>
                                <% } %>
                            </a>
                        </li>
                    <% }); %>
                </ul>
            </div>
        <% } %>
        
        <% if (data.spell_correction) { %>
            <div class="autocomplete-section spell-correction">
                <p><?= $block->escapeHtml(__('Did you mean:')) ?> 
                   <a href="#" class="spell-suggestion" data-suggestion="<%- data.spell_correction %>">
                       <%- data.spell_correction %>
                   </a>
                </p>
            </div>
        <% } %>
    </div>
</script>
<?php endif; ?>