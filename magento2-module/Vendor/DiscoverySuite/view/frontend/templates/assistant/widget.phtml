<!-- Message Templates -->
<script type="text/x-magento-template" id="user-message-template">
    <div class="message user-message">
        <div class="message-content">
            <p><%- message %></p>
        </div>
        <div class="message-timestamp"><%- timestamp %></div>
    </div>
</script>

<script type="text/x-magento-template" id="assistant-message-template">
    <div class="message assistant-message">
        <div class="message-avatar">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" fill="#007bff"/>
                <path d="M12 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 9c-2.7 0-5.8 1.29-6 2h12c-.2-.71-3.3-2-6-2z" fill="white"/>
            </svg>
        </div>
        <div class="message-content">
            <p><%- message %></p>
            <% if (questions && questions.length > 0) { %>
                <div class="message-questions">
                    <% _.each(questions, function(question) { %>
                        <button type="button" class="quick-reply-btn" data-reply="<%- question.text %>">
                            <%- question.text %>
                        </button>
                    <% }); %>
                </div>
            <% } %>
        </div>
        <div class="message-timestamp"><%- timestamp %></div>
    </div>
</script>

<script type="text/x-magento-template" id="product-suggestion-template">
    <div class="product-suggestion" data-product-id="<%- product.id %>">
        <div class="product-image">
            <% if (product.image) { %>
                <img src="<%- product.image %>" alt="<%- product.name %>">
            <% } else { %>
                <div class="no-image"><?= $block->escapeHtml(__('No Image')) ?></div>
            <% } %>
        </div>
        <div class="product-info">
            <h5 class="product-name"><%- product.name %></h5>
            <div class="product-price"><%- product.price %></div>
            <% if (product.rating) { %>
                <div class="product-rating">
                    <span class="rating-stars" style="width: <%- product.rating * 20 %>%"></span>
                </div>
            <% } %>
        </div>
        <div class="product-actions">
            <button type="button" class="btn-view-product" data-url="<%- product.url %>">
                <?= $block->escapeHtml(__('View Product')) ?>
            </button>
        </div>
    </div>
</script>

<script type="text/x-magento-template" id="guided-flow-question-template">
    <div class="flow-question" data-question-id="<%- question.id %>">
        <h4 class="question-title"><%- question.title %></h4>
        <% if (question.description) { %>
            <p class="question-description"><%- question.description %></p>
        <% } %>
        
        <div class="question-options">
            <% if (question.type === 'multiple_choice') { %>
                <% _.each(question.options, function(option) { %>
                    <label class="option-label">
                        <input type="radio" name="question_<%- question.id %>" value="<%- option.value %>">
                        <span class="option-text"><%- option.text %></span>
                    </label>
                <% }); %>
            <% } else if (question.type === 'text') { %>
                <input type="text" class="question-input" placeholder="<%- question.placeholder || '' %>">
            <% } else if (question.type === 'range') { %>
                <div class="range-input">
                    <input type="range" min="<%- question.min %>" max="<%- question.max %>" value="<%- question.default %>">
                    <div class="range-labels">
                        <span><%- question.min_label %></span>
                        <span><%- question.max_label %></span>
                    </div>
                </div>
            <% } %>
        </div>
        
        <div class="question-actions">
            <% if (question.can_skip) { %>
                <button type="button" class="btn-skip"><?= $block->escapeHtml(__('Skip')) ?></button>
            <% } %>
            <button type="button" class="btn-next"><?= $block->escapeHtml(__('Next')) ?></button>
        </div>
    </div>
</script>
<?php endif; ?>