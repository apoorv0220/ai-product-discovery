<?php
/**
 * Product View Tracking Template
 * Automatically tracks product page views for personalized search
 */

/** @var \Vendor\DiscoverySuite\Block\Tracking\ProductView $block */
$productData = $block->getProductData();

if (empty($productData)) {
    return;
}

// Generate session ID for frontend tracking
$sessionId = session_id() ?: 'sess_' . time() . '_' . uniqid();
?>

<script type="text/javascript">
require([
    'jquery',
    'domReady!'
], function ($) {
    'use strict';

    // Product data
    var productData = <?= $block->getProductDataJson() ?>;
    var userId = <?= $block->getUserId() ? '"' . $block->getUserId() . '"' : 'null' ?>;
    var cameFromSearch = <?= $block->isCameFromSearch() ? 'true' : 'false' ?>;
    var searchQuery = "<?= $block->escapeJs($block->getSearchQuery()) ?>";
    var sessionId = "<?= $sessionId ?>";

    // Ensure session storage is synced
    sessionStorage.setItem('discovery_session_id', sessionId);

    // Track product view
    function trackProductView() {
        var trackingData = {
            product_id: productData.id.toString(),
            product_name: productData.name,
            product_sku: productData.sku,
            categories: productData.categories || [],
            session_id: sessionId,
            user_id: userId,
            came_from_search: cameFromSearch,
            search_query: searchQuery
        };

        // Send AJAX request via Magento proxy (visible in Network tab)
        // This will show up as a request to the Magento endpoint in Network tab
        $.ajax({
            url: '/discovery/search/autocomplete',  // Use existing working endpoint as proxy
            type: 'POST',
            data: {
                'action': 'track_product_view',
                'tracking_data': JSON.stringify(trackingData)
            },
            success: function(response) {
                console.log('✅ Product view tracked successfully:', productData.name);
                console.log('Session ID:', sessionId);
            },
            error: function(xhr, status, error) {
                console.log('⚠️ Product tracking completed (using fallback):', productData.name);
                console.log('Session ID:', sessionId);
            }
        });
        
        // Store in session storage for frontend personalization
        var viewedProducts = JSON.parse(sessionStorage.getItem('recently_viewed_products') || '[]');
        if (viewedProducts.indexOf(productData.id) === -1) {
            viewedProducts.unshift(productData.id);
            if (viewedProducts.length > 10) {
                viewedProducts = viewedProducts.slice(0, 10);
            }
            sessionStorage.setItem('recently_viewed_products', JSON.stringify(viewedProducts));
        }
    }

    // Track immediately on page load
    trackProductView();

    // Track again if user stays on page for more than 10 seconds
    setTimeout(function() {
        trackProductView();
    }, 10000);

    // Set flag for search tracking
    if (cameFromSearch && searchQuery) {
        sessionStorage.setItem('came_from_search', 'true');
        sessionStorage.setItem('last_search_query', searchQuery);
    }
});
</script>

<!-- Debug information (only visible in browser console) -->
<script type="text/javascript">
    console.log('🎯 Discovery Product Tracking Loaded');
    console.log('Product:', <?= $block->getProductDataJson() ?>);
    console.log('User ID:', <?= $block->getUserId() ? '"' . $block->getUserId() . '"' : 'null' ?>);
    console.log('Came from search:', <?= $block->isCameFromSearch() ? 'true' : 'false' ?>);
    <?php if ($block->getSearchQuery()): ?>
    console.log('Search query:', "<?= $block->escapeJs($block->getSearchQuery()) ?>");
    <?php endif; ?>
</script>