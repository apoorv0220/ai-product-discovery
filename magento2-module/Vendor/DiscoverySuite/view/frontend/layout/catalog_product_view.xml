<?xml version="1.0"?>
<!--
/**
 * Product View Layout - Add Personalized Search Tracking
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!-- Product tracking handled by template -->
    </head>
    <body>
        <referenceContainer name="content">
            <block class="Vendor\DiscoverySuite\Block\Tracking\ProductView" 
                   name="discovery.product.tracking" 
                   template="Vendor_DiscoverySuite::tracking/product_view.phtml"
                   after="-"/>
        </referenceContainer>
        
        <!-- Add tracking to product recommendations section -->
        <referenceContainer name="content.aside">
            <block class="Vendor\DiscoverySuite\Block\Recommendations\Product" 
                   name="discovery.recommendations.product" 
                   template="Vendor_DiscoverySuite::recommendations/product.phtml"
                   after="-"/>
        </referenceContainer>
    </body>
</page>