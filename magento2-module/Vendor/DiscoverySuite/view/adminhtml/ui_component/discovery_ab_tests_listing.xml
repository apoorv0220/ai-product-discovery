<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">discovery_ab_tests_listing.discovery_ab_tests_listing_data_source</item>
            <item name="deps" xsi:type="string">discovery_ab_tests_listing.discovery_ab_tests_listing_data_source</item>
        </item>
        <item name="spinner" xsi:type="string">discovery_ab_tests_columns</item>
        <item name="buttons" xsi:type="array">
            <item name="add" xsi:type="array">
                <item name="name" xsi:type="string">add</item>
                <item name="label" xsi:type="string" translate="true">Create New A/B Test</item>
                <item name="class" xsi:type="string">primary</item>
                <item name="url" xsi:type="string">*/*/new</item>
            </item>
        </item>
    </argument>
    
    <dataSource name="discovery_ab_tests_listing_data_source">
        <argument name="dataProvider" xsi:type="configurableObject">
            <argument name="class" xsi:type="string">Vendor\DiscoverySuite\Ui\Component\DataProvider\ABTestDataProvider</argument>
            <argument name="name" xsi:type="string">discovery_ab_tests_listing_data_source</argument>
            <argument name="primaryFieldName" xsi:type="string">test_id</argument>
            <argument name="requestFieldName" xsi:type="string">test_id</argument>
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="component" xsi:type="string">Magento_Ui/js/grid/provider</item>
                    <item name="update_url" xsi:type="url" path="mui/index/render"/>
                    <item name="storageConfig" xsi:type="array">
                        <item name="indexField" xsi:type="string">test_id</item>
                    </item>
                </item>
            </argument>
        </argument>
    </dataSource>
    
    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <filters name="listing_filters"/>
        <massaction name="listing_massaction">
            <action name="start">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="type" xsi:type="string">start</item>
                        <item name="label" xsi:type="string" translate="true">Start Tests</item>
                        <item name="url" xsi:type="url" path="discovery/abtest/massStart"/>
                        <item name="confirm" xsi:type="array">
                            <item name="title" xsi:type="string" translate="true">Start A/B Tests</item>
                            <item name="message" xsi:type="string" translate="true">Are you sure you want to start the selected A/B tests?</item>
                        </item>
                    </item>
                </argument>
            </action>
            <action name="stop">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="type" xsi:type="string">stop</item>
                        <item name="label" xsi:type="string" translate="true">Stop Tests</item>
                        <item name="url" xsi:type="url" path="discovery/abtest/massStop"/>
                        <item name="confirm" xsi:type="array">
                            <item name="title" xsi:type="string" translate="true">Stop A/B Tests</item>
                            <item name="message" xsi:type="string" translate="true">Are you sure you want to stop the selected A/B tests?</item>
                        </item>
                    </item>
                </argument>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>
    
    <columns name="discovery_ab_tests_columns">
        <selectionsColumn name="ids">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="resizeEnabled" xsi:type="boolean">false</item>
                    <item name="resizeDefaultWidth" xsi:type="string">55</item>
                    <item name="indexField" xsi:type="string">test_id</item>
                </item>
            </argument>
        </selectionsColumn>
        
        <column name="test_name">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Test Name</item>
                    <item name="sorting" xsi:type="string">asc</item>
                </item>
            </argument>
        </column>
        
        <column name="status">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">select</item>
                    <item name="label" xsi:type="string" translate="true">Status</item>
                    <item name="component" xsi:type="string">Magento_Ui/js/grid/columns/select</item>
                    <item name="dataType" xsi:type="string">select</item>
                    <item name="options" xsi:type="array">
                        <item name="draft" xsi:type="array">
                            <item name="value" xsi:type="string">draft</item>
                            <item name="label" xsi:type="string" translate="true">Draft</item>
                        </item>
                        <item name="running" xsi:type="array">
                            <item name="value" xsi:type="string">running</item>
                            <item name="label" xsi:type="string" translate="true">Running</item>
                        </item>
                        <item name="paused" xsi:type="array">
                            <item name="value" xsi:type="string">paused</item>
                            <item name="label" xsi:type="string" translate="true">Paused</item>
                        </item>
                        <item name="completed" xsi:type="array">
                            <item name="value" xsi:type="string">completed</item>
                            <item name="label" xsi:type="string" translate="true">Completed</item>
                        </item>
                    </item>
                </item>
            </argument>
        </column>
        
        <column name="primary_metric">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Primary Metric</item>
                </item>
            </argument>
        </column>
        
        <column name="traffic_allocation">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">textRange</item>
                    <item name="label" xsi:type="string" translate="true">Traffic %</item>
                </item>
            </argument>
        </column>
        
        <column name="statistical_significance" class="Vendor\DiscoverySuite\Ui\Component\Listing\Column\SignificanceStatus">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="label" xsi:type="string" translate="true">Significance</item>
                    <item name="sortable" xsi:type="boolean">false</item>
                </item>
            </argument>
        </column>
        
        <column name="start_date" class="Magento\Ui\Component\Listing\Columns\Date">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">dateRange</item>
                    <item name="component" xsi:type="string">Magento_Ui/js/grid/columns/date</item>
                    <item name="dataType" xsi:type="string">date</item>
                    <item name="label" xsi:type="string" translate="true">Start Date</item>
                </item>
            </argument>
        </column>
        
        <column name="end_date" class="Magento\Ui\Component\Listing\Columns\Date">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">dateRange</item>
                    <item name="component" xsi:type="string">Magento_Ui/js/grid/columns/date</item>
                    <item name="dataType" xsi:type="string">date</item>
                    <item name="label" xsi:type="string" translate="true">End Date</item>
                </item>
            </argument>
        </column>
        
        <actionsColumn name="actions" class="Vendor\DiscoverySuite\Ui\Component\Listing\Column\ABTestActions">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="resizeEnabled" xsi:type="boolean">false</item>
                    <item name="resizeDefaultWidth" xsi:type="string">107</item>
                    <item name="indexField" xsi:type="string">test_id</item>
                </item>
            </argument>
        </actionsColumn>
    </columns>
</listing>